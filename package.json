{
  "name": "@microsoft/teams.ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/microsoft/teams.ts",
  "bugs": "https://github.com/microsoft/teams.ts/issues",
  "packageManager": "npm@10.8.1",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/teams.ts.git"
  },
  "workspaces": [
    "packages/*",
    "external/*",
    "examples/*"
  ],
  "keywords": [
    "microsoft",
    "teams",
    "msteams",
    "copilot",
    "ai",
    "adaptive-cards",
    "apps",
    "bots"
  ],
  "scripts": {
    "version:stamp": "node scripts/version.js",
    "version:get": "nbgv get-version -v NpmPackageVersion",
    "clean": "npm run clean --workspaces --if-present",
    "build": "tsc --build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "npm test --workspaces --if-present"
  },
  "devDependencies": {
    "eslint": "^9.25.1",
    "neostandard": "^0.13.0",
    "nerdbank-gitversioning": "^3.9.50",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "restify": {
      "send": "^1.2.0",
      "find-my-way": "^9.0.0"
    }
  }
}
