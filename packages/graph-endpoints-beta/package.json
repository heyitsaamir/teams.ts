{
  "name": "@microsoft/teams.graph-endpoints-beta",
  "sideEffects": false,
  "version": "0.0.0",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/microsoft/teams.ts",
  "bugs": "https://github.com/microsoft/teams.ts/issues",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/teams.ts.git",
    "directory": "packages/graph-endpoints-beta"
  },
  "keywords": [
    "microsoft",
    "teams",
    "msteams",
    "copilot",
    "graph"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc --build",
    "gen": "npm run gen:types && npm run gen:endpoints",
    "gen:types": "npx cross-env NODE_OPTIONS='--max-old-space-size=16384' npx @microsoft/teams.graph-tools generate-types ../graph/openapi-beta.yaml ./src beta",
    "gen:endpoints": "npx cross-env NODE_OPTIONS='--max-old-space-size=16384' npx @microsoft/teams.graph-tools generate-endpoints ../graph/openapi-beta.yaml ./src beta"
  },
  "devDependencies": {
    "@microsoft/teams.graph-tools": "*",
    "typescript": "^5.8.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./*": {
      "require": [
        "./dist/*/index.js"
      ],
      "import": [
        "./dist/*/index.js"
      ]
    },
    "./*/*": {
      "require": [
        "./dist/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/index.js"
      ]
    },
    "./*/*/*": {
      "require": [
        "./dist/*/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/*/index.js"
      ]
    },
    "./*/*/*/*": {
      "require": [
        "./dist/*/*/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/*/*/index.js"
      ]
    },
    "./*/*/*/*/*": {
      "require": [
        "./dist/*/*/*/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/*/*/*/index.js"
      ]
    },
    "./*/*/*/*/*/*": {
      "require": [
        "./dist/*/*/*/*/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/*/*/*/*/index.js"
      ]
    },
    "./*/*/*/*/*/*/*": {
      "require": [
        "./dist/*/*/*/*/*/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/*/*/*/*/*/index.js"
      ]
    },
    "./*/*/*/*/*/*/*/*": {
      "require": [
        "./dist/*/*/*/*/*/*/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/*/*/*/*/*/*/index.js"
      ]
    },
    "./*/*/*/*/*/*/*/*/*": {
      "require": [
        "./dist/*/*/*/*/*/*/*/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/*/*/*/*/*/*/*/index.js"
      ]
    },
    "./*/*/*/*/*/*/*/*/*/*": {
      "require": [
        "./dist/*/*/*/*/*/*/*/*/*/*/index.js"
      ],
      "import": [
        "./dist/*/*/*/*/*/*/*/*/*/*/index.js"
      ]
    }
  },
  "type": "module"
}
